              "paso-rapido/conceptos",
              "paso-rapido/tags",
              "paso-rapido/importar-consumos",
              "paso-rapido/validar-consumos",
              "paso-rapido/gestionar-consumos",
              "paso-rapido/revision-manual",
              "paso-rapido/reporte-consumos",
              "paso-rapido/exportar"
            ]
          },
          {
            "group": "Combustible",
            "pages": [
              "combustible/index",
              "combustible/entradas",
              "combustible/productos",
              "combustible/proveedores",
              "combustible/importar",
              "combustible/reporte-rendimiento"
            ]
          },
          {
            "group": "Flota y telemática",
            "pages": [
              "flota/index",
              "flota/mapa-en-vivo",
              "flota/flotas",
              "flota/vehiculos",
              "flota/viajes",
              "flota/eventos",
              "flota/conductores",
              "flota/pois"
            ]
          },
          {
            "group": "Reportes",
            "pages": [
              "reportes/index",
              "reportes/conduccion",
              "reportes/jornada-conductor",
              "reportes/velocidad",
              "reportes/paradas-no-autorizadas"
            ]
          },
          {
            "group": "Alertas",
            "pages": [
              "alertas/index"
            ]
          },
          {
            "group": "Configuración",
            "pages": [
              "configuracion/index",
              "configuracion/usuarios",
              "configuracion/api-keys"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "groups": [
          {
            "group": "Guía",
            "pages": [
              "api/index",
              "api/autenticacion",
              "api/errores-paginacion",
              "api/legacy-topkat"
