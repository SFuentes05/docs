  "logo": {
    "light": "/logo/united-petroleum-logo.png",
    "dark": "/logo/united-petroleum-logo.png"
  },
  "api": {
    "playground": {
      "display": "interactive"
    }
  },
  "footerSocials": {
    "website": "https://unitedlogistics.com.do"
  },
  "search": {
